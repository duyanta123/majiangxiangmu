<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysPointsLogMapper">
    <resultMap type="com.ruoyi.system.domain.SysPointsLog" id="SysPointsLogResult">
        <result property="logId" column="log_id"/><result property="memberId" column="member_id"/>
        <result property="playerName" column="player_name"/><result property="playerPhone" column="player_phone"/>
        <result property="changeType" column="change_type"/><result property="points" column="points"/>
        <result property="balanceBefore" column="balance_before"/><result property="balanceAfter" column="balance_after"/>
        <result property="sourceType" column="source_type"/><result property="sourceId" column="source_id"/>
        <result property="description" column="description"/><result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <sql id="selectLogVo">
        select log_id, member_id, player_name, player_phone, change_type, points, balance_before, balance_after,
        source_type, source_id, description, remark, create_time from sys_points_log
    </sql>
    <select id="selectPointsLogList" parameterType="com.ruoyi.system.domain.SysPointsLog" resultMap="SysPointsLogResult">
        <include refid="selectLogVo"/>
        <if test="memberId != null">AND member_id = #{memberId}</if>
        <if test="playerName != null">AND player_name like concat('%', #{playerName}, '%')</if>
        <if test="changeType != null">AND change_type = #{changeType}</if>
        order by create_time desc
    </select>
    <select id="selectPointsLogById" parameterType="Long" resultMap="SysPointsLogResult">
        <include refid="selectLogVo"/> where log_id = #{logId}
    </select>
    <insert id="insertPointsLog" parameterType="com.ruoyi.system.domain.SysPointsLog" useGeneratedKeys="true" keyProperty="logId">
        insert into sys_points_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="memberId != null">member_id,</if><if test="playerName != null">player_name,</if>
            <if test="playerPhone != null">player_phone,</if><if test="changeType != null">change_type,</if>
            <if test="points != null">points,</if><if test="balanceBefore != null">balance_before,</if>
            <if test="balanceAfter != null">balance_after,</if><if test="sourceType != null">source_type,</if>
            <if test="sourceId != null">source_id,</if><if test="description != null">description,</if>
            <if test="remark != null">remark,</if>create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="memberId != null">#{memberId},</if><if test="playerName != null">#{playerName},</if>
            <if test="playerPhone != null">#{playerPhone},</if><if test="changeType != null">#{changeType},</if>
            <if test="points != null">#{points},</if><if test="balanceBefore != null">#{balanceBefore},</if>
            <if test="balanceAfter != null">#{balanceAfter},</if><if test="sourceType != null">#{sourceType},</if>
            <if test="sourceId != null">#{sourceId},</if><if test="description != null">#{description},</if>
            <if test="remark != null">#{remark},</if>sysdate()
        </trim>
    </insert>
    <update id="updatePointsLog" parameterType="com.ruoyi.system.domain.SysPointsLog">
        update sys_points_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="memberId != null">member_id = #{memberId},</if>
            <if test="playerName != null">player_name = #{playerName},</if>
            <if test="playerPhone != null">player_phone = #{playerPhone},</if>
            <if test="changeType != null">change_type = #{changeType},</if>
            <if test="points != null">points = #{points},</if>
            <if test="balanceBefore != null">balance_before = #{balanceBefore},</if>
            <if test="balanceAfter != null">balance_after = #{balanceAfter},</if>
            <if test="sourceType != null">source_type = #{sourceType},</if>
            <if test="sourceId != null">source_id = #{sourceId},</if>
            <if test="description != null">description = #{description},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where log_id = #{logId}
    </update>
    <delete id="deletePointsLogByIds" parameterType="Long">
        delete from sys_points_log where log_id in
        <foreach item="logId" collection="array" open="(" separator="," close=")">#{logId}</foreach>
    </delete>
</mapper>
