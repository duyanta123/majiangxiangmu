<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysReservationMapper">
    <resultMap type="com.ruoyi.system.domain.SysReservation" id="SysReservationResult">
        <result property="reservationId" column="reservation_id"/><result property="reservationCode" column="reservation_code"/>
        <result property="appReservationId" column="app_reservation_id"/>
        <result property="playerId" column="player_id"/><result property="playerName" column="player_name"/>
        <result property="playerPhone" column="player_phone"/><result property="storeId" column="store_id"/>
        <result property="storeName" column="store_name"/><result property="tableId" column="table_id"/>
        <result property="tableName" column="table_name"/><result property="tableCode" column="table_code"/>
        <result property="reserveDate" column="reserve_date"/><result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/><result property="playHours" column="play_hours"/>
        <result property="estimatedAmount" column="estimated_amount"/><result property="actualAmount" column="actual_amount"/>
        <result property="reservationStatus" column="reservation_status"/><result property="payStatus" column="pay_status"/>
        <result property="payMethod" column="pay_method"/><result property="payTime" column="pay_time"/>
        <result property="deposit" column="deposit"/><result property="checkInTime" column="check_in_time"/>
        <result property="checkOutTime" column="check_out_time"/><result property="remark" column="remark"/>
        <result property="delFlag" column="del_flag"/><result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>
    <sql id="selectReservationVo">
        select reservation_id, reservation_code, app_reservation_id, player_id, player_name, player_phone, store_id, store_name,
        table_id, table_name, table_code, reserve_date, start_time, end_time, play_hours, estimated_amount,
        actual_amount, reservation_status, pay_status, pay_method, pay_time, deposit, check_in_time, check_out_time,
        remark, del_flag, create_time, update_time from sys_reservation
    </sql>
    <select id="selectReservationList" parameterType="com.ruoyi.system.domain.SysReservation" resultMap="SysReservationResult">
        <include refid="selectReservationVo"/> where del_flag = '0'
        <if test="playerName != null and playerName != ''">AND player_name like concat('%', #{playerName}, '%')</if>
        <if test="storeId != null">AND store_id = #{storeId}</if>
        <if test="reservationStatus != null and reservationStatus != ''">AND reservation_status = #{reservationStatus}</if>
        <if test="payStatus != null and payStatus != ''">AND pay_status = #{payStatus}</if>
        order by create_time desc
    </select>
    <select id="selectReservationById" parameterType="Long" resultMap="SysReservationResult">
        <include refid="selectReservationVo"/> where reservation_id = #{reservationId}
    </select>
    <select id="checkReservationCodeUnique" resultMap="SysReservationResult">
        <include refid="selectReservationVo"/> where reservation_code = #{reservationCode} and del_flag = '0'
    </select>
    <insert id="insertReservation" parameterType="com.ruoyi.system.domain.SysReservation" useGeneratedKeys="true" keyProperty="reservationId">
        insert into sys_reservation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="reservationCode != null">reservation_code,</if>
            <if test="playerId != null">player_id,</if><if test="playerName != null">player_name,</if>
            <if test="playerPhone != null">player_phone,</if><if test="storeId != null">store_id,</if>
            <if test="storeName != null">store_name,</if><if test="tableId != null">table_id,</if>
            <if test="tableName != null">table_name,</if><if test="tableCode != null">table_code,</if>
            <if test="reserveDate != null">reserve_date,</if><if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if><if test="playHours != null">play_hours,</if>
            <if test="estimatedAmount != null">estimated_amount,</if><if test="actualAmount != null">actual_amount,</if>
            <if test="reservationStatus != null">reservation_status,</if><if test="payStatus != null">pay_status,</if>
            <if test="payMethod != null">pay_method,</if><if test="deposit != null">deposit,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="reservationCode != null">#{reservationCode},</if>
            <if test="playerId != null">#{playerId},</if><if test="playerName != null">#{playerName},</if>
            <if test="playerPhone != null">#{playerPhone},</if><if test="storeId != null">#{storeId},</if>
            <if test="storeName != null">#{storeName},</if><if test="tableId != null">#{tableId},</if>
            <if test="tableName != null">#{tableName},</if><if test="tableCode != null">#{tableCode},</if>
            <if test="reserveDate != null">#{reserveDate},</if><if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if><if test="playHours != null">#{playHours},</if>
            <if test="estimatedAmount != null">#{estimatedAmount},</if><if test="actualAmount != null">#{actualAmount},</if>
            <if test="reservationStatus != null">#{reservationStatus},</if><if test="payStatus != null">#{payStatus},</if>
            <if test="payMethod != null">#{payMethod},</if><if test="deposit != null">#{deposit},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>sysdate()
        </trim>
    </insert>
    <update id="updateReservation" parameterType="com.ruoyi.system.domain.SysReservation">
        update sys_reservation
        <trim prefix="SET" suffixOverrides=",">
            <if test="reservationStatus != null">reservation_status = #{reservationStatus},</if>
            <if test="payStatus != null">pay_status = #{payStatus},</if>
            <if test="payMethod != null">pay_method = #{payMethod},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="actualAmount != null">actual_amount = #{actualAmount},</if>
            <if test="checkInTime != null">check_in_time = #{checkInTime},</if>
            <if test="checkOutTime != null">check_out_time = #{checkOutTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where reservation_id = #{reservationId}
    </update>
    <delete id="deleteReservationByIds" parameterType="Long">
        update sys_reservation set del_flag = '1' where reservation_id in
        <foreach item="reservationId" collection="array" open="(" separator="," close=")">#{reservationId}</foreach>
    </delete>
</mapper>
